{
  "name": "mdblog",
  "version": "0.1.0",
  "imports": {
    "marked": "npm:marked@^15",
    "gray-matter": "npm:gray-matter@^4",
    "@std/cli": "jsr:@std/cli@^1",
    "@std/fs": "jsr:@std/fs@^1",
    "@std/path": "jsr:@std/path@^1",
    "@std/assert": "jsr:@std/assert@^1"
  },
  "tasks": {
    "build": "deno run --allow-read --allow-write main.ts",
    "test": "deno test --allow-read --allow-write tests/"
  },
  "compilerOptions": {
    "strict": true
  }
}
